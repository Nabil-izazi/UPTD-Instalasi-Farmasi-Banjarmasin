            <linearGradient id="gradGold" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#D4AF37"/><stop offset="100%" stop-color="#F0D060"/>
            </linearGradient>
            <linearGradient id="gradGlass" x1="0%" y1="0%" x2="0%" y2="100%">
