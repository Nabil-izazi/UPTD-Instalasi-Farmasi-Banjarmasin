<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UPTD Instalasi Farmasi Kota Banjarmasin | Company Profile</title>
<meta name="description" content="Profil resmi UPTD Instalasi Farmasi Kota Banjarmasin yang mengelola penyimpanan dan distribusi obat, vaksin, dan alat kesehatan secara profesional.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --emerald:#0B5D4B; --teal:#14B8A6; --navy:#0F172A; --navy-2:#1E293B;
  --white:#F8FAFC; --gray:#E2E8F0; --gray-2:#94A3B8;
  --gold:#D4AF37; --gold-light:#F0D060;
  --glass:rgba(255,255,255,0.04); --glass-2:rgba(255,255,255,0.07);
  --glass-border:rgba(255,255,255,0.1);
  --teal-glow:rgba(20,184,166,.35);
  --gradient-main:linear-gradient(135deg,#0F172A 0%,#0B5D4B 50%,#14B8A6 100%);
  --gradient-card:linear-gradient(145deg,rgba(20,184,166,.08),rgba(11,93,75,.04));
  --font:'Plus Jakarta Sans',-apple-system,sans-serif;
  --mono:'DM Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{font-family:var(--font);background:var(--navy);color:var(--white);overflow-x:hidden;line-height:1.65;font-weight:400;-webkit-font-smoothing:antialiased}
img{max-width:100%;display:block}
::selection{background:var(--teal);color:var(--navy)}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--navy)}
::-webkit-scrollbar-thumb{background:linear-gradient(var(--emerald),var(--teal));border-radius:3px}

/* PROGRESS BAR */
#progress{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--teal),var(--gold));z-index:9999;width:0%;box-shadow:0 0 12px var(--teal-glow)}

/* LOADER */
#loader{position:fixed;inset:0;background:var(--navy);z-index:10000;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:28px;transition:opacity .7s,visibility .7s}
#loader.hidden{opacity:0;visibility:hidden}
.l-ring{width:72px;height:72px;position:relative}
.l-ring::before,.l-ring::after{content:'';position:absolute;inset:0;border-radius:50%;border:2px solid transparent}
.l-ring::before{border-top-color:var(--teal);animation:spin 1s linear infinite}
.l-ring::after{inset:10px;border-bottom-color:var(--gold);animation:spin 1.4s linear infinite reverse}
.l-text{font-family:var(--mono);font-size:11px;letter-spacing:5px;color:var(--teal);text-transform:uppercase;opacity:.6}
@keyframes spin{to{transform:rotate(360deg)}}

/* BACKGROUNDS */
.bg-layer{position:fixed;inset:0;z-index:-1;pointer-events:none}
.bg-gradient{background:radial-gradient(ellipse at top right,rgba(11,93,75,.4),transparent 50%),radial-gradient(ellipse at bottom left,rgba(20,184,166,.2),transparent 50%),var(--navy)}
.bg-grid{background-image:linear-gradient(rgba(20,184,166,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(20,184,166,.035) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(ellipse at center,black 30%,transparent 80%);-webkit-mask-image:radial-gradient(ellipse at center,black 30%,transparent 80%)}
.orb{position:fixed;border-radius:50%;filter:blur(120px);z-index:-1;pointer-events:none;opacity:.5;animation:float 20s ease-in-out infinite}
.orb-1{width:600px;height:600px;background:rgba(11,93,75,.5);top:-200px;right:-150px}
.orb-2{width:500px;height:500px;background:rgba(20,184,166,.25);bottom:5%;left:-100px;animation-delay:-7s}
.orb-3{width:400px;height:400px;background:rgba(212,175,55,.1);top:40%;left:30%;animation-delay:-14s}
@keyframes float{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(40px,-30px) scale(1.1)}66%{transform:translate(-30px,40px) scale(.95)}}

#particles{position:fixed;inset:0;z-index:-1;pointer-events:none;opacity:.4}

/* NAVBAR */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:18px 0;transition:all .4s}
nav.scrolled{background:rgba(15,23,42,.78);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid var(--glass-border);padding:12px 0}
.nav-inner{max-width:1320px;margin:0 auto;padding:0 32px;display:flex;align-items:center;justify-content:space-between;gap:24px}
.logo{display:flex;align-items:center;gap:14px;text-decoration:none;cursor:pointer}
.logo-mark{width:46px;height:46px;background:linear-gradient(135deg,var(--emerald),var(--teal));border-radius:13px;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 20px rgba(20,184,166,.3),inset 0 1px 0 rgba(255,255,255,.15);position:relative;overflow:hidden}
.logo-mark::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,transparent 40%,rgba(255,255,255,.15));border-radius:13px}
.logo-mark svg{width:24px;height:24px;color:var(--white);z-index:1}
.logo-text{display:flex;flex-direction:column;line-height:1.1}
.logo-name{font-size:15px;font-weight:800;letter-spacing:-.3px;color:var(--white)}
.logo-sub{font-size:10px;color:var(--teal);letter-spacing:1.5px;font-family:var(--mono);text-transform:uppercase;margin-top:3px}
.nav-menu{display:flex;align-items:center;gap:4px;list-style:none}
.nav-menu a{color:rgba(248,250,252,.7);text-decoration:none;font-size:13.5px;font-weight:500;padding:9px 14px;border-radius:9px;transition:all .3s;position:relative}
.nav-menu a:hover{color:var(--white)}
.nav-menu a::after{content:'';position:absolute;bottom:5px;left:50%;width:0;height:2px;background:var(--teal);border-radius:1px;transition:width .3s,left .3s;transform:translateX(-50%)}
.nav-menu a:hover::after{width:18px}
.nav-cta{background:linear-gradient(135deg,var(--emerald),var(--teal))!important;color:var(--white)!important;padding:11px 22px!important;border-radius:11px!important;font-weight:600!important;box-shadow:0 6px 24px var(--teal-glow);transition:all .3s!important;display:inline-flex!important;align-items:center;gap:8px}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 10px 30px var(--teal-glow)}
.nav-cta::after{display:none!important}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:10px;border-radius:9px;background:var(--glass);border:1px solid var(--glass-border)}
.hamburger span{width:22px;height:2px;background:var(--white);border-radius:1px;transition:.3s}
.hamburger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hamburger.open span:nth-child(2){opacity:0}
.hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
.mobile-menu{display:none;position:fixed;top:75px;left:16px;right:16px;background:rgba(15,23,42,.96);backdrop-filter:blur(24px);padding:18px;flex-direction:column;border-radius:18px;border:1px solid var(--glass-border);z-index:999}
.mobile-menu.open{display:flex}
.mobile-menu a{color:rgba(248,250,252,.85);text-decoration:none;padding:14px 16px;font-size:15px;font-weight:500;border-radius:10px;border-bottom:1px solid rgba(255,255,255,.05)}
.mobile-menu a:last-child{border:none;background:linear-gradient(135deg,var(--emerald),var(--teal));text-align:center;margin-top:8px}
.mobile-menu a:hover{background:var(--glass)}

/* SECTIONS */
section{padding:120px 0;position:relative}
.container{max-width:1320px;margin:0 auto;padding:0 32px}
.s-badge{display:inline-flex;align-items:center;gap:10px;background:rgba(20,184,166,.1);border:1px solid rgba(20,184,166,.25);color:var(--teal);font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:2.5px;text-transform:uppercase;padding:7px 16px;border-radius:100px;margin-bottom:24px}
.s-badge .dot{width:6px;height:6px;background:var(--teal);border-radius:50%;box-shadow:0 0 8px var(--teal);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.s-title{font-size:clamp(32px,4.5vw,54px);font-weight:800;line-height:1.1;letter-spacing:-1.8px;margin-bottom:20px}
.s-title .accent{background:linear-gradient(135deg,var(--teal),var(--gold-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.s-sub{font-size:17px;color:rgba(248,250,252,.6);max-width:620px;line-height:1.7}
.s-head{text-align:center;margin:0 auto 70px;max-width:760px}
.s-head .s-sub{margin:0 auto}

/* REVEAL */
.reveal{opacity:0;transform:translateY(40px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal.in{opacity:1;transform:translateY(0)}
.reveal-l{opacity:0;transform:translateX(-40px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal-l.in{opacity:1;transform:translateX(0)}
.reveal-r{opacity:0;transform:translateX(40px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal-r.in{opacity:1;transform:translateX(0)}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}.d5{transition-delay:.5s}.d6{transition-delay:.6s}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:10px;padding:14px 26px;border-radius:12px;font-weight:600;font-size:14.5px;cursor:pointer;border:none;text-decoration:none;transition:all .3s;font-family:var(--font)}
.btn-primary{background:linear-gradient(135deg,var(--emerald),var(--teal));color:var(--white);box-shadow:0 8px 28px var(--teal-glow);position:relative;overflow:hidden}
.btn-primary::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transition:left .6s}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 36px var(--teal-glow)}
.btn-primary:hover::before{left:100%}
.btn-ghost{background:var(--glass);border:1px solid var(--glass-border);color:var(--white);backdrop-filter:blur(12px)}
.btn-ghost:hover{background:var(--glass-2);border-color:var(--teal);transform:translateY(-2px)}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--navy);box-shadow:0 8px 28px rgba(212,175,55,.3)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 12px 36px rgba(212,175,55,.45)}

/* ============ HERO ============ */
#beranda{padding:140px 0 100px;min-height:100vh;display:flex;align-items:center}
.hero{display:grid;grid-template-columns:1.05fr 1fr;gap:80px;align-items:center}
.hero-badge{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,rgba(212,175,55,.12),rgba(20,184,166,.08));border:1px solid rgba(212,175,55,.3);padding:8px 18px;border-radius:100px;margin-bottom:28px;font-size:12px;font-weight:600;color:var(--gold-light);letter-spacing:.5px}
.hero-badge::before{content:'';width:8px;height:8px;background:var(--gold);border-radius:50%;box-shadow:0 0 10px var(--gold)}
.hero h1{font-size:clamp(38px,5.2vw,64px);font-weight:800;line-height:1.08;letter-spacing:-2px;margin-bottom:24px}
.hero h1 .grad{background:linear-gradient(135deg,#F8FAFC,#14B8A6 60%,#D4AF37);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero p.sub{font-size:18px;color:rgba(248,250,252,.65);line-height:1.7;margin-bottom:36px;max-width:540px}
.hero-cta{display:flex;gap:14px;margin-bottom:48px;flex-wrap:wrap}
.trust{display:flex;gap:32px;flex-wrap:wrap;padding-top:28px;border-top:1px solid var(--glass-border)}
.trust-item{display:flex;align-items:center;gap:10px;font-size:13px;color:rgba(248,250,252,.7);font-weight:500}
.trust-item svg{color:var(--teal);width:18px;height:18px;flex-shrink:0}

/* HERO ILLUSTRATION */
.hero-vis{position:relative;height:580px}
.hero-vis-glow{position:absolute;inset:0;background:radial-gradient(circle at center,rgba(20,184,166,.25),transparent 60%);filter:blur(40px)}
.warehouse-svg{position:absolute;inset:0;width:100%;height:100%;animation:gentle 8s ease-in-out infinite}
@keyframes gentle{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.float-card{position:absolute;background:rgba(15,23,42,.7);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid var(--glass-border);border-radius:16px;padding:14px 18px;box-shadow:0 20px 40px rgba(0,0,0,.4);animation:floatcard 6s ease-in-out infinite}
.fc-1{top:8%;right:-2%;animation-delay:0s}
.fc-2{top:42%;left:-6%;animation-delay:-2s}
.fc-3{bottom:8%;right:8%;animation-delay:-4s}
@keyframes floatcard{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
.fc-row{display:flex;align-items:center;gap:12px}
.fc-icon{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--emerald),var(--teal));display:flex;align-items:center;justify-content:center;color:var(--white);box-shadow:0 0 16px var(--teal-glow)}
.fc-icon svg{width:18px;height:18px}
.fc-label{font-size:10px;color:var(--gray-2);font-family:var(--mono);letter-spacing:1px;text-transform:uppercase}
.fc-value{font-size:16px;font-weight:700;color:var(--white);margin-top:2px}
.fc-3 .fc-value{color:var(--gold-light)}

/* ============ STATS ============ */
#statistik{padding:60px 0 120px}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.stat-card{background:var(--gradient-card);border:1px solid var(--glass-border);border-radius:24px;padding:36px 28px;position:relative;overflow:hidden;transition:all .4s;backdrop-filter:blur(12px)}
.stat-card::before{content:'';position:absolute;top:-50%;right:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(20,184,166,.1),transparent 50%);opacity:0;transition:opacity .5s}
.stat-card:hover{transform:translateY(-6px);border-color:rgba(20,184,166,.4);box-shadow:0 24px 50px rgba(0,0,0,.4)}
.stat-card:hover::before{opacity:1}
.stat-icon{width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,rgba(11,93,75,.5),rgba(20,184,166,.25));border:1px solid rgba(20,184,166,.3);display:flex;align-items:center;justify-content:center;color:var(--teal);margin-bottom:24px;position:relative;z-index:1}
.stat-icon svg{width:22px;height:22px}
.stat-num{font-size:48px;font-weight:800;line-height:1;letter-spacing:-2px;background:linear-gradient(135deg,var(--white),var(--teal));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px;position:relative;z-index:1}
.stat-num .plus{color:var(--gold);-webkit-text-fill-color:var(--gold)}
.stat-label{font-size:13px;color:var(--gray-2);font-weight:500;line-height:1.5;position:relative;z-index:1}

/* ============ ABOUT ============ */
.about-grid{display:grid;grid-template-columns:1fr 1.1fr;gap:80px;align-items:center}
.about-left h2{margin-bottom:24px}
.about-points{margin-top:32px;display:flex;flex-direction:column;gap:18px}
.about-point{display:flex;gap:16px;padding:18px 20px;background:var(--glass);border:1px solid var(--glass-border);border-radius:16px;backdrop-filter:blur(8px);transition:all .3s}
.about-point:hover{border-color:rgba(20,184,166,.3);transform:translateX(4px)}
.ap-icon{flex-shrink:0;width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,var(--emerald),var(--teal));display:flex;align-items:center;justify-content:center;color:var(--white)}
.ap-icon svg{width:18px;height:18px}
.ap-title{font-size:15px;font-weight:700;margin-bottom:4px}
.ap-desc{font-size:13.5px;color:var(--gray-2);line-height:1.55}

/* TIMELINE */
.timeline{position:relative;padding-left:24px}
.timeline::before{content:'';position:absolute;left:0;top:14px;bottom:14px;width:2px;background:linear-gradient(180deg,var(--teal),var(--emerald),transparent)}
.tl-item{position:relative;padding:18px 0 18px 36px;display:flex;align-items:flex-start;gap:16px}
.tl-item::before{content:'';position:absolute;left:-7px;top:28px;width:16px;height:16px;border-radius:50%;background:var(--navy);border:2px solid var(--teal);box-shadow:0 0 14px var(--teal-glow)}
.tl-item::after{content:'';position:absolute;left:-3px;top:32px;width:8px;height:8px;border-radius:50%;background:var(--teal)}
.tl-num{font-family:var(--mono);font-size:11px;color:var(--gold-light);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;display:block}
.tl-name{font-size:18px;font-weight:700;margin-bottom:6px}
.tl-desc{font-size:14px;color:var(--gray-2);line-height:1.6}
.tl-card{background:var(--glass);border:1px solid var(--glass-border);border-radius:16px;padding:22px;backdrop-filter:blur(8px);flex:1;transition:all .3s}
.tl-card:hover{border-color:rgba(20,184,166,.3);background:var(--glass-2)}

/* ============ SERVICES ============ */
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.service-card{background:var(--gradient-card);border:1px solid var(--glass-border);border-radius:24px;padding:36px 30px;position:relative;overflow:hidden;transition:all .4s;backdrop-filter:blur(12px);cursor:pointer}
.service-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(20,184,166,.08),transparent 70%);opacity:0;transition:opacity .5s;border-radius:24px}
.service-card::after{content:'';position:absolute;inset:0;border-radius:24px;padding:1px;background:linear-gradient(135deg,var(--teal),transparent 50%);-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;opacity:0;transition:opacity .4s}
.service-card:hover{transform:translateY(-8px);box-shadow:0 30px 60px rgba(0,0,0,.5)}
.service-card:hover::before,.service-card:hover::after{opacity:1}
.svc-num{position:absolute;top:24px;right:28px;font-family:var(--mono);font-size:11px;color:rgba(212,175,55,.6);letter-spacing:2px}
.svc-icon{width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,rgba(11,93,75,.6),rgba(20,184,166,.3));border:1px solid rgba(20,184,166,.3);display:flex;align-items:center;justify-content:center;color:var(--teal);margin-bottom:24px;transition:all .4s;position:relative;z-index:1}
.svc-icon svg{width:26px;height:26px;transition:transform .4s}
.service-card:hover .svc-icon{background:linear-gradient(135deg,var(--emerald),var(--teal));color:var(--white);box-shadow:0 0 24px var(--teal-glow)}
.service-card:hover .svc-icon svg{transform:rotate(-8deg) scale(1.1)}
.svc-title{font-size:20px;font-weight:700;margin-bottom:12px;letter-spacing:-.3px;position:relative;z-index:1}
.svc-desc{font-size:14.5px;color:var(--gray-2);line-height:1.65;position:relative;z-index:1}

/* ============ DISTRIBUTION WORKFLOW ============ */
#distribusi{padding:120px 0}
.workflow{position:relative;margin-top:40px}
.wf-line{position:absolute;top:48px;left:6%;right:6%;height:2px;background:linear-gradient(90deg,transparent,var(--teal) 10%,var(--teal) 90%,transparent);opacity:.4}
.wf-line::after{content:'';position:absolute;top:-1px;left:0;width:30%;height:4px;background:linear-gradient(90deg,transparent,var(--teal),var(--gold));border-radius:2px;box-shadow:0 0 16px var(--teal-glow);animation:flow 4s ease-in-out infinite}
@keyframes flow{0%{left:-30%}100%{left:100%}}
.wf-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;position:relative;z-index:1}
.wf-step{text-align:center;padding:20px 12px}
.wf-dot{width:96px;height:96px;margin:0 auto 22px;border-radius:50%;background:rgba(15,23,42,.9);border:2px solid var(--glass-border);display:flex;align-items:center;justify-content:center;color:var(--teal);transition:all .4s;position:relative;backdrop-filter:blur(8px)}
.wf-dot::before{content:'';position:absolute;inset:-6px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--gold));opacity:0;transition:opacity .4s;z-index:-1;filter:blur(10px)}
.wf-step:hover .wf-dot{border-color:var(--teal);transform:scale(1.08);color:var(--white);background:linear-gradient(135deg,var(--emerald),var(--teal))}
.wf-step:hover .wf-dot::before{opacity:.6}
.wf-dot svg{width:36px;height:36px}
.wf-num{font-family:var(--mono);font-size:11px;color:var(--gold-light);letter-spacing:2px;margin-bottom:6px}
.wf-name{font-size:14.5px;font-weight:700;color:var(--white);margin-bottom:6px;letter-spacing:-.2px}
.wf-info{font-size:12px;color:var(--gray-2);line-height:1.5}

/* ============ QUALITY ============ */
.quality-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.q-card{background:var(--gradient-card);border:1px solid var(--glass-border);border-radius:24px;padding:32px 24px;backdrop-filter:blur(12px);position:relative;overflow:hidden;transition:all .4s}
.q-card:hover{transform:translateY(-6px);border-color:rgba(212,175,55,.3)}
.q-badge{position:absolute;top:24px;right:24px;display:flex;align-items:center;gap:6px;background:rgba(212,175,55,.15);border:1px solid rgba(212,175,55,.3);padding:4px 10px;border-radius:100px;font-size:9px;color:var(--gold-light);font-family:var(--mono);letter-spacing:1.5px;text-transform:uppercase}
.q-icon{width:52px;height:52px;border-radius:13px;background:linear-gradient(135deg,rgba(212,175,55,.2),rgba(20,184,166,.15));border:1px solid rgba(212,175,55,.25);display:flex;align-items:center;justify-content:center;color:var(--gold-light);margin-bottom:22px}
.q-icon svg{width:24px;height:24px}
.q-title{font-size:18px;font-weight:700;margin-bottom:14px;letter-spacing:-.3px}
.q-list{display:flex;flex-direction:column;gap:10px;margin-top:14px}
.q-li{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:rgba(248,250,252,.75);line-height:1.5}
.q-li svg{flex-shrink:0;width:16px;height:16px;color:var(--teal);margin-top:2px}

/* ============ GALLERY ============ */
.gallery{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:140px;gap:14px}
.gal-item{position:relative;border-radius:18px;overflow:hidden;cursor:pointer;border:1px solid var(--glass-border);background:var(--gradient-card)}
.gal-item.tall{grid-row:span 2}
.gal-item.wide{grid-column:span 2}
.gal-bg{position:absolute;inset:0;transition:transform .6s ease-out}
.gal-item:hover .gal-bg{transform:scale(1.08)}
.gal-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(15,23,42,.95));display:flex;align-items:flex-end;padding:20px;opacity:0;transition:opacity .4s}
.gal-item:hover .gal-overlay{opacity:1}
.gal-cat{font-family:var(--mono);font-size:10px;color:var(--teal);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px}
.gal-title{font-size:15px;font-weight:700;letter-spacing:-.2px}

/* ============ DASHBOARD ============ */
.dash-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:24px;margin-bottom:24px}
.dash-grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.dash-card{background:var(--gradient-card);border:1px solid var(--glass-border);border-radius:24px;padding:28px;backdrop-filter:blur(12px);position:relative;overflow:hidden}
.dc-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px}
.dc-title{font-size:15px;font-weight:700;letter-spacing:-.2px;margin-bottom:4px}
.dc-meta{font-size:11px;color:var(--gray-2);font-family:var(--mono);letter-spacing:1px;text-transform:uppercase}
.dc-pill{display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);color:#4ADE80;padding:5px 11px;border-radius:100px;font-size:11px;font-weight:600;font-family:var(--mono)}
.dc-pill svg{width:11px;height:11px}
.dc-value{font-size:38px;font-weight:800;letter-spacing:-1.5px;line-height:1;margin-bottom:8px;background:linear-gradient(135deg,var(--white),var(--teal));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.dc-label{font-size:13px;color:var(--gray-2);margin-bottom:20px}
.chart-area{height:200px;position:relative}
.legend{display:flex;gap:18px;margin-top:16px;flex-wrap:wrap}
.leg-item{display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--gray-2);font-family:var(--mono)}
.leg-dot{width:8px;height:8px;border-radius:50%}

.progress-grid{display:flex;flex-direction:column;gap:18px;margin-top:8px}
.prog-row{display:flex;flex-direction:column;gap:8px}
.prog-head{display:flex;justify-content:space-between;align-items:center}
.prog-name{font-size:13.5px;font-weight:600}
.prog-val{font-family:var(--mono);font-size:13px;color:var(--teal);font-weight:600}
.prog-track{height:8px;background:rgba(255,255,255,.06);border-radius:100px;overflow:hidden;position:relative}
.prog-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,var(--emerald),var(--teal));position:relative;width:0;transition:width 1.4s ease-out}
.prog-fill::after{content:'';position:absolute;right:0;top:-2px;width:12px;height:12px;background:var(--teal);border-radius:50%;box-shadow:0 0 12px var(--teal)}
.prog-fill.gold{background:linear-gradient(90deg,var(--gold),var(--gold-light))}
.prog-fill.gold::after{background:var(--gold);box-shadow:0 0 12px var(--gold)}

/* ============ TESTIMONIALS ============ */
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.testi-card{background:var(--gradient-card);border:1px solid var(--glass-border);border-radius:24px;padding:32px;backdrop-filter:blur(12px);position:relative;transition:all .4s}
.testi-card:hover{transform:translateY(-6px);border-color:rgba(20,184,166,.3)}
.testi-quote{position:absolute;top:24px;right:28px;font-family:Georgia,serif;font-size:80px;line-height:1;color:rgba(20,184,166,.15);font-weight:800}
.testi-stars{display:flex;gap:3px;margin-bottom:18px;color:var(--gold)}
.testi-stars svg{width:16px;height:16px}
.testi-text{font-size:15px;line-height:1.7;color:rgba(248,250,252,.8);margin-bottom:24px;position:relative;z-index:1}
.testi-author{display:flex;align-items:center;gap:14px;padding-top:22px;border-top:1px solid var(--glass-border)}
.testi-avatar{width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--emerald),var(--teal));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:var(--white);box-shadow:0 0 16px var(--teal-glow)}
.testi-info-name{font-size:14.5px;font-weight:700;letter-spacing:-.2px}
.testi-info-role{font-size:12px;color:var(--gray-2);margin-top:2px}

/* ============ CONTACT ============ */
.contact-grid{display:grid;grid-template-columns:1fr 1.15fr;gap:60px;align-items:start}
.contact-info{display:flex;flex-direction:column;gap:18px;margin-top:36px}
.ci-card{display:flex;gap:18px;padding:22px 24px;background:var(--glass);border:1px solid var(--glass-border);border-radius:18px;backdrop-filter:blur(8px);transition:all .3s}
.ci-card:hover{transform:translateX(6px);border-color:rgba(20,184,166,.3)}
.ci-icon{flex-shrink:0;width:46px;height:46px;border-radius:12px;background:linear-gradient(135deg,var(--emerald),var(--teal));display:flex;align-items:center;justify-content:center;color:var(--white);box-shadow:0 0 16px var(--teal-glow)}
.ci-icon svg{width:20px;height:20px}
.ci-label{font-size:11px;color:var(--gray-2);font-family:var(--mono);letter-spacing:2px;text-transform:uppercase;margin-bottom:4px}
.ci-value{font-size:14.5px;font-weight:500;color:var(--white);line-height:1.5}
.form-card{background:var(--gradient-card);border:1px solid var(--glass-border);border-radius:24px;padding:36px;backdrop-filter:blur(12px)}
.form-card h3{font-size:22px;font-weight:700;margin-bottom:6px;letter-spacing:-.5px}
.form-card .form-sub{font-size:14px;color:var(--gray-2);margin-bottom:28px}
.form-row{margin-bottom:18px}
.form-row label{display:block;font-size:11.5px;font-family:var(--mono);color:var(--gray-2);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px}
.form-input{width:100%;padding:14px 18px;background:rgba(15,23,42,.6);border:1px solid var(--glass-border);border-radius:12px;color:var(--white);font-family:var(--font);font-size:14.5px;transition:all .3s;outline:none}
.form-input:focus{border-color:var(--teal);background:rgba(15,23,42,.8);box-shadow:0 0 0 3px rgba(20,184,166,.15)}
.form-input::placeholder{color:rgba(248,250,252,.3)}
textarea.form-input{resize:vertical;min-height:130px;font-family:var(--font)}
.map{margin-top:36px;border-radius:18px;overflow:hidden;border:1px solid var(--glass-border);height:280px;position:relative;background:var(--navy-2)}
.map iframe{width:100%;height:100%;border:0;filter:invert(.92) hue-rotate(180deg) saturate(.7)}

/* ============ FINAL CTA ============ */
.final-cta{margin:60px 32px;max-width:1320px}
.final-cta-inner{background:linear-gradient(135deg,rgba(11,93,75,.4),rgba(20,184,166,.15));border:1px solid rgba(20,184,166,.3);border-radius:32px;padding:80px 60px;text-align:center;position:relative;overflow:hidden;backdrop-filter:blur(12px)}
.final-cta-inner::before{content:'';position:absolute;top:-50%;left:-25%;width:150%;height:200%;background:radial-gradient(ellipse at center,rgba(20,184,166,.2),transparent 50%);animation:pulse2 6s ease-in-out infinite}
@keyframes pulse2{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.05)}}
.final-cta h2{font-size:clamp(28px,3.8vw,46px);font-weight:800;line-height:1.15;letter-spacing:-1.5px;margin-bottom:24px;position:relative;z-index:1}
.final-cta h2 .acc{background:linear-gradient(135deg,var(--teal),var(--gold-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.final-cta p{font-size:17px;color:rgba(248,250,252,.7);max-width:620px;margin:0 auto 36px;position:relative;z-index:1;line-height:1.7}
.final-cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;position:relative;z-index:1}

/* ============ FOOTER ============ */
footer{padding:80px 0 32px;border-top:1px solid var(--glass-border);background:rgba(15,23,42,.4);backdrop-filter:blur(12px)}
.foot-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:60px;margin-bottom:60px}
.foot-desc{margin-top:24px;font-size:14px;color:var(--gray-2);line-height:1.7;max-width:380px}
.foot-social{display:flex;gap:10px;margin-top:24px}
.foot-social a{width:40px;height:40px;border-radius:10px;background:var(--glass);border:1px solid var(--glass-border);display:flex;align-items:center;justify-content:center;color:var(--gray);transition:all .3s;text-decoration:none}
.foot-social a:hover{background:linear-gradient(135deg,var(--emerald),var(--teal));color:var(--white);transform:translateY(-3px);border-color:transparent;box-shadow:0 8px 20px var(--teal-glow)}
.foot-social svg{width:18px;height:18px}
.foot-h{font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--white);margin-bottom:22px;font-family:var(--mono)}
.foot-links{display:flex;flex-direction:column;gap:12px;list-style:none}
.foot-links a{color:var(--gray-2);text-decoration:none;font-size:14px;transition:all .3s;display:inline-flex;align-items:center;gap:8px}
.foot-links a:hover{color:var(--teal);transform:translateX(4px)}
.foot-links a::before{content:'→';color:var(--teal);opacity:0;transition:opacity .3s}
.foot-links a:hover::before{opacity:1}
.foot-bottom{padding-top:32px;border-top:1px solid var(--glass-border);display:flex;justify-content:space-between;flex-wrap:wrap;gap:16px;font-size:13px;color:var(--gray-2)}
.foot-bottom .fb-right{display:flex;gap:20px}
.foot-bottom a{color:var(--gray-2);text-decoration:none;transition:color .3s}
.foot-bottom a:hover{color:var(--teal)}

/* ============ RESPONSIVE ============ */
@media(max-width:1100px){
  .hero,.about-grid,.contact-grid{grid-template-columns:1fr;gap:60px}
  .hero-vis{height:480px;max-width:520px;margin:0 auto;width:100%}
  .services-grid,.stats-grid,.quality-grid,.testi-grid{grid-template-columns:repeat(2,1fr)}
  .wf-grid{grid-template-columns:repeat(3,1fr);gap:30px 14px}
  .wf-line{display:none}
  .dash-grid{grid-template-columns:1fr}
  .foot-grid{grid-template-columns:1fr 1fr;gap:40px}
}
@media(max-width:720px){
  section{padding:80px 0}
  .container{padding:0 22px}
  .nav-menu{display:none}
  .hamburger{display:flex}
  .nav-cta{display:none!important}
  .stats-grid,.services-grid,.quality-grid,.testi-grid,.gallery,.dash-grid-2{grid-template-columns:1fr}
  .gallery{grid-auto-rows:180px}
  .gal-item.tall,.gal-item.wide{grid-row:auto;grid-column:auto}
  .wf-grid{grid-template-columns:repeat(2,1fr)}
  .foot-grid{grid-template-columns:1fr;gap:40px}
  .final-cta-inner{padding:50px 30px}
  .form-card{padding:28px 24px}
  .hero h1{font-size:38px}
  .trust{gap:18px}
  .final-cta{margin:40px 16px}
}
</style>
