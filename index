<script>
// LOADER
window.addEventListener('load',()=>{
  setTimeout(()=>document.getElementById('loader').classList.add('hidden'),600);
});

// PROGRESS BAR
window.addEventListener('scroll',()=>{
  const h=document.documentElement;
  const p=(h.scrollTop/(h.scrollHeight-h.clientHeight))*100;
  document.getElementById('progress').style.width=p+'%';
  const nav=document.getElementById('navbar');
  if(window.scrollY>40)nav.classList.add('scrolled');else nav.classList.remove('scrolled');
});

// MOBILE MENU
const hb=document.getElementById('hamburger');
const mm=document.getElementById('mobileMenu');
hb.addEventListener('click',()=>{hb.classList.toggle('open');mm.classList.toggle('open');});
mm.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{hb.classList.remove('open');mm.classList.remove('open');}));

// REVEAL ON SCROLL
const io=new IntersectionObserver(e=>{
  e.forEach(en=>{if(en.isIntersecting){en.target.classList.add('in');io.unobserve(en.target);}});
},{threshold:0.12,rootMargin:'-50px'});
document.querySelectorAll('.reveal,.reveal-l,.reveal-r').forEach(el=>io.observe(el));

// COUNTERS
const counterIO=new IntersectionObserver(e=>{
  e.forEach(en=>{
    if(en.isIntersecting){
      const el=en.target;
      const target=parseInt(el.dataset.target);
      let cur=0;
      const dur=1800;
      const step=target/(dur/16);
      const t=setInterval(()=>{
        cur+=step;
        if(cur>=target){cur=target;clearInterval(t);}
        el.textContent=Math.floor(cur).toLocaleString('id-ID');
      },16);
      counterIO.unobserve(el);
    }
  });
},{threshold:0.4});
document.querySelectorAll('.counter').forEach(c=>counterIO.observe(c));

// PROGRESS BARS
const progIO=new IntersectionObserver(e=>{
  e.forEach(en=>{
    if(en.isIntersecting){
      const el=en.target;
      setTimeout(()=>{el.style.width=el.dataset.val+'%';},200);
      progIO.unobserve(el);
    }
  });
},{threshold:0.4});
document.querySelectorAll('.prog-fill').forEach(p=>progIO.observe(p));

// CHART: LINE
function drawLineChart(){
  const c=document.getElementById('chartLine');
  if(!c)return;
  const dpr=window.devicePixelRatio||1;
  const w=c.clientWidth,h=c.clientHeight;
  c.width=w*dpr;c.height=h*dpr;
  const ctx=c.getContext('2d');
  ctx.scale(dpr,dpr);
  ctx.clearRect(0,0,w,h);
  
  const data=[94,95,96,93,97,98,96,97,99,98,99,99];
  const target=[95,95,95,95,95,95,95,95,95,95,95,95];
  const months=['J','F','M','A','M','J','J','A','S','O','N','D'];
  const padL=30,padR=10,padT=20,padB=30;
  const cw=w-padL-padR,ch=h-padT-padB;
  
  // grid
  ctx.strokeStyle='rgba(255,255,255,0.05)';
  ctx.lineWidth=1;
  for(let i=0;i<=4;i++){
    const y=padT+(ch/4)*i;
    ctx.beginPath();ctx.moveTo(padL,y);ctx.lineTo(w-padR,y);ctx.stroke();
  }
  // y labels
  ctx.fillStyle='rgba(255,255,255,0.4)';
  ctx.font='10px DM Mono';
  ctx.textAlign='right';
  [100,97,94,91,88].forEach((v,i)=>ctx.fillText(v+'%',padL-6,padT+(ch/4)*i+3));
  // x labels
  ctx.textAlign='center';
  months.forEach((m,i)=>ctx.fillText(m,padL+(cw/(months.length-1))*i,h-12));
  
  // target line (dashed gold)
  ctx.strokeStyle='rgba(212,175,55,0.5)';
  ctx.lineWidth=1.5;
  ctx.setLineDash([4,4]);
  ctx.beginPath();
  target.forEach((v,i)=>{
    const x=padL+(cw/(target.length-1))*i;
    const y=padT+ch-((v-88)/12)*ch;
    if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);
  });
  ctx.stroke();
  ctx.setLineDash([]);
  
  // area gradient
  const grad=ctx.createLinearGradient(0,padT,0,h-padB);
  grad.addColorStop(0,'rgba(20,184,166,0.4)');
  grad.addColorStop(1,'rgba(20,184,166,0)');
  ctx.fillStyle=grad;
  ctx.beginPath();
  data.forEach((v,i)=>{
    const x=padL+(cw/(data.length-1))*i;
    const y=padT+ch-((v-88)/12)*ch;
    if(i===0){ctx.moveTo(x,h-padB);ctx.lineTo(x,y);}else ctx.lineTo(x,y);
  });
  ctx.lineTo(w-padR,h-padB);
  ctx.closePath();
  ctx.fill();
  
  // main line
  ctx.strokeStyle='#14B8A6';
  ctx.lineWidth=2.5;
  ctx.beginPath();
  data.forEach((v,i)=>{
    const x=padL+(cw/(data.length-1))*i;
    const y=padT+ch-((v-88)/12)*ch;
    if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);
  });
  ctx.stroke();
  
  // dots
  data.forEach((v,i)=>{
    const x=padL+(cw/(data.length-1))*i;
    const y=padT+ch-((v-88)/12)*ch;
    ctx.fillStyle='#0F172A';
    ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle='#14B8A6';
    ctx.lineWidth=2;
    ctx.beginPath();ctx.arc(x,y,4,0,Math.PI*2);ctx.stroke();
  });
}

// CHART: DONUT
function drawDonut(){
  const c=document.getElementById('chartDonut');
  if(!c)return;
  const dpr=window.devicePixelRatio||1;
  const w=c.clientWidth,h=c.clientHeight;
  c.width=w*dpr;c.height=h*dpr;
  const ctx=c.getContext('2d');
  ctx.scale(dpr,dpr);
  
  const cx=w/2,cy=h/2,r=Math.min(w,h)/2-20;
  const value=0.992;
  
  // background ring
  ctx.strokeStyle='rgba(255,255,255,0.06)';
  ctx.lineWidth=14;
  ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.stroke();
  
  // progress
  const grad=ctx.createLinearGradient(0,0,w,h);
  grad.addColorStop(0,'#0B5D4B');
  grad.addColorStop(0.6,'#14B8A6');
  grad.addColorStop(1,'#D4AF37');
  ctx.strokeStyle=grad;
  ctx.lineWidth=14;
  ctx.lineCap='round';
  ctx.beginPath();
  ctx.arc(cx,cy,r,-Math.PI/2,-Math.PI/2+Math.PI*2*value);
  ctx.stroke();
  
  // center text
  ctx.fillStyle='#F8FAFC';
  ctx.font='600 11px DM Mono';
  ctx.textAlign='center';
  ctx.fillText('SLA',cx,cy-4);
  ctx.fillStyle='#14B8A6';
  ctx.font='700 18px Plus Jakarta Sans';
  ctx.fillText('99.2%',cx,cy+16);
}

// CHART: BAR
function drawBar(){
  const c=document.getElementById('chartBar');
  if(!c)return;
  const dpr=window.devicePixelRatio||1;
  const w=c.clientWidth,h=c.clientHeight;
  c.width=w*dpr;c.height=h*dpr;
  const ctx=c.getContext('2d');
  ctx.scale(dpr,dpr);
  
  const data=[
    {label:'Picking',val:96},
    {label:'Packing',val:94},
    {label:'Verifikasi',val:98},
    {label:'Shipping',val:92},
    {label:'Reporting',val:95}
  ];
  const padL=25,padR=10,padT=20,padB=35;
  const cw=w-padL-padR,ch=h-padT-padB;
  const bw=cw/data.length*0.55;
  const gap=cw/data.length*0.45;
  
  // grid
  ctx.strokeStyle='rgba(255,255,255,0.05)';
  for(let i=0;i<=4;i++){
    const y=padT+(ch/4)*i;
    ctx.beginPath();ctx.moveTo(padL,y);ctx.lineTo(w-padR,y);ctx.stroke();
  }
  ctx.fillStyle='rgba(255,255,255,0.4)';
  ctx.font='9px DM Mono';
  ctx.textAlign='right';
  [100,90,80,70,60].forEach((v,i)=>ctx.fillText(v,padL-4,padT+(ch/4)*i+3));
  
  data.forEach((d,i)=>{
    const x=padL+(cw/data.length)*i+gap/2;
    const bh=((d.val-60)/40)*ch;
    const y=padT+ch-bh;
    const grad=ctx.createLinearGradient(0,y,0,padT+ch);
    grad.addColorStop(0,'#14B8A6');
    grad.addColorStop(1,'#0B5D4B');
    ctx.fillStyle=grad;
    // rounded top bar
    const r=4;
    ctx.beginPath();
    ctx.moveTo(x+r,y);
    ctx.lineTo(x+bw-r,y);
    ctx.quadraticCurveTo(x+bw,y,x+bw,y+r);
    ctx.lineTo(x+bw,y+bh);
    ctx.lineTo(x,y+bh);
    ctx.lineTo(x,y+r);
    ctx.quadraticCurveTo(x,y,x+r,y);
    ctx.fill();
    
    // value label
    ctx.fillStyle='#14B8A6';
    ctx.font='600 10px DM Mono';
    ctx.textAlign='center';
    ctx.fillText(d.val+'%',x+bw/2,y-6);
    // category label
    ctx.fillStyle='rgba(255,255,255,0.55)';
    ctx.font='10px Plus Jakarta Sans';
    ctx.fillText(d.label,x+bw/2,h-12);
  });
}

// Init charts when visible
const chartIO=new IntersectionObserver(e=>{
  e.forEach(en=>{
    if(en.isIntersecting){
      drawLineChart();
      drawDonut();
      drawBar();
      chartIO.disconnect();
    }
  });
},{threshold:0.2});
const lineEl=document.getElementById('chartLine');
if(lineEl)chartIO.observe(lineEl);

window.addEventListener('resize',()=>{
  drawLineChart();drawDonut();drawBar();
});

// PARTICLES BACKGROUND
const canvas=document.getElementById('particles');
const pctx=canvas.getContext('2d');
let particles=[];
function resizeCanvas(){
  canvas.width=window.innerWidth;
  canvas.height=window.innerHeight;
}
resizeCanvas();
window.addEventListener('resize',resizeCanvas);

class Particle{
  constructor(){
    this.x=Math.random()*canvas.width;
    this.y=Math.random()*canvas.height;
    this.vx=(Math.random()-0.5)*0.3;
    this.vy=(Math.random()-0.5)*0.3;
    this.size=Math.random()*1.5+0.5;
    this.opacity=Math.random()*0.4+0.1;
    this.color=Math.random()>0.85?'#D4AF37':'#14B8A6';
  }
  update(){
    this.x+=this.vx;this.y+=this.vy;
    if(this.x<0||this.x>canvas.width)this.vx*=-1;
    if(this.y<0||this.y>canvas.height)this.vy*=-1;
  }
  draw(){
    pctx.beginPath();
    pctx.arc(this.x,this.y,this.size,0,Math.PI*2);
    pctx.fillStyle=this.color;
    pctx.globalAlpha=this.opacity;
    pctx.fill();
  }
}
for(let i=0;i<40;i++)particles.push(new Particle());
function animateParticles(){
  pctx.clearRect(0,0,canvas.width,canvas.height);
  particles.forEach(p=>{p.update();p.draw();});
  // Connect close particles
  pctx.globalAlpha=0.15;
  pctx.strokeStyle='#14B8A6';
  pctx.lineWidth=0.5;
  for(let i=0;i<particles.length;i++){
    for(let j=i+1;j<particles.length;j++){
      const dx=particles[i].x-particles[j].x;
      const dy=particles[i].y-particles[j].y;
      const d=Math.sqrt(dx*dx+dy*dy);
      if(d<140){
        pctx.beginPath();
        pctx.moveTo(particles[i].x,particles[i].y);
        pctx.lineTo(particles[j].x,particles[j].y);
        pctx.globalAlpha=(1-d/140)*0.15;
        pctx.stroke();
      }
    }
  }
  requestAnimationFrame(animateParticles);
}
animateParticles();
</script>

